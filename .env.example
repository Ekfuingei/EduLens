# Backend (Cloud Run / local server)
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Frontend (Vercel only) — WebSocket URL to Cloud Run backend
# Use wss:// for production, e.g. wss://edulens-xxx-uc.a.run.app/ws
# Leave unset when frontend and backend share the same origin
# VITE_WS_URL=wss://your-cloud-run-url.run.app/ws
